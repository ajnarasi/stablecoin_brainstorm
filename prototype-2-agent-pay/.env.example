# =============================================================================
# Fiserv x402 Agent Commerce Prototype - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# --- Blockchain RPC Endpoints ---
SOLANA_RPC_URL=https://api.devnet.solana.com
BASE_RPC_URL=https://sepolia.base.org

# --- Wallet Keys (base58 for Solana, hex for EVM) ---
# WARNING: Never commit real private keys. These are for devnet/testnet only.
MERCHANT_WALLET_PRIVATE_KEY=your-merchant-private-key-here
AGENT_WALLET_PRIVATE_KEY=your-agent-private-key-here

# --- Merchant Wallet Addresses ---
MERCHANT_WALLET_SOLANA=FsrvMerchant1111111111111111111111111111111
MERCHANT_WALLET_BASE=0x742d35Cc6634C0532925a3b844Bc9e7595f2bD18

# --- Token Contract Addresses ---
FIUSD_MINT_ADDRESS=FiUSDxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
USDC_SOLANA_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
USDC_BASE_ADDRESS=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# --- Finxact API (for KYC tier checks) ---
FINXACT_BASE_URL=https://sandbox.finxact.com/api/v1
FINXACT_API_KEY=your-finxact-api-key

# --- Anthropic API (for demo agent) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Service Ports ---
GATEWAY_PORT=8002
VERIFIER_PORT=8003
SETTLER_PORT=8004

# --- Service URLs (for inter-service communication) ---
GATEWAY_URL=http://localhost:8002
VERIFIER_URL=http://localhost:8003
SETTLER_URL=http://localhost:8004

# --- Gateway Signing ---
GATEWAY_SIGNING_SECRET=x402-gateway-signing-key-change-in-production
